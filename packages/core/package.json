{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@connectfx/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir dist --target bun --format esm",
    "lint": "bun --cwd ../.. oxlint packages/core/src packages/core/test",
    "test": "bun --cwd ../.. vitest run packages/core/test --passWithNoTests",
    "typecheck": "bun tsc --noEmit"
  },
  "dependencies": {
    "effect": "catalog:"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:",
    "@types/bun": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
