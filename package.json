{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "connectfx",
  "description": "Effect-native framework for durable external-system connections",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "workspaces": {
    "packages": [
      "packages/*",
      "apps/*"
    ],
    "catalog": {
      "@ast-grep/cli": "0.44.0",
      "@effect/vitest": "4.0.0-beta.93",
      "@foldkit/ui": "0.122.0",
      "@foldkit/vite-plugin": "0.10.0",
      "@tailwindcss/vite": "4.3.2",
      "@tsconfig/bun": "1.0.9",
      "@types/bun": "1.3.13",
      "@types/node": "24.12.2",
      "@vitest/coverage-v8": "4.0.16",
      "class-variance-authority": "0.7.1",
      "clsx": "2.1.1",
      "effect": "4.0.0-beta.93",
      "foldkit": "0.122.0",
      "happy-dom": "20.10.6",
      "oxlint": "1.60.0",
      "oxlint-tsgolint": "0.21.0",
      "prettier": "3.6.2",
      "tailwind-merge": "3.6.0",
      "tailwindcss": "4.3.2",
      "turbo": "2.8.13",
      "typescript": "5.8.2",
      "vite": "8.1.3",
      "vitest": "4.0.16"
    }
  },
  "scripts": {
    "build": "bun turbo build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "oxlint packages apps && ast-grep scan --config sgconfig.yml",
    "test": "bun turbo test",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "bun turbo typecheck",
    "verify:docs-deploy": "bash scripts/verify-docs-deploy.sh"
  },
  "prettier": {
    "printWidth": 120,
    "semi": false
  },
  "devDependencies": {
    "@ast-grep/cli": "catalog:",
    "@effect/vitest": "catalog:",
    "@tsconfig/bun": "catalog:",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "prettier": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
